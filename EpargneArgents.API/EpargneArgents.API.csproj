<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\EpargneArgents.Business\EpargneArgents.Business.csproj" />
  </ItemGroup>

  <!-- Include static files from Blazor frontend for publishing -->
  <ItemGroup>
    <StaticFiles Include="..\EpargneArgents.Client.Web\wwwroot\**" />
  </ItemGroup>

  <Target Name="PublishBlazorAssets" BeforeTargets="Build">
    <Message Text="Preparing Blazor frontend assets for web hosting..." Importance="high" />
    <!-- This will be executed during build to prepare frontend assets -->
  </Target>

</Project>
